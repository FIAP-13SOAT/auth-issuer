# Ambiente
ENVIRONMENT=dev

# Database - Desenvolvimento
DB_HOST_DEV=garage-postgres
DB_PORT_DEV=5432
DB_USER_DEV=secret
DB_PASSWORD_DEV=secret
DB_NAME_DEV=garage

# Database - Produção
DB_HOST_PROD=your-rds-endpoint.rds.amazonaws.com
DB_PORT_PROD=5432
DB_USER_PROD=your-user
DB_PASSWORD_PROD=your-password
DB_NAME_PROD=your-database

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
